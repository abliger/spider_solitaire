# Godot 4+ 编辑器缓存和导入文件
.godot/

# 导出目录
export/
export_presets.cfg

# Android / iOS 导出模板
android/
ios/

# iOS 导出产物（包含超过 100MB 的静态库）
MoltenVK.xcframework/
Spider Solitaire.xcframework/
Spider Solitaire.xcodeproj/
Spider Solitaire/
Spider Solitaire.pck
PrivacyInfo.xcprivacy

# 构建目录
build/

# 临时文件
*.tmp

# macOS 系统文件
.DS_Store

# AI agent 配置（可选，如需保留请注释掉）
.agents/

# 测试残留文件（仅排除项目根目录下的临时测试文件）
/test_*.gd.uid
/test_*.gd
